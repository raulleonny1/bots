<%- include('partials/head', { bodyClass: 'login-body' }) %>

<div class="login-page">
  <div class="login-card">
    <div class="login-card__top">
      <img src="/assets/logo.png" alt="<%= botName %>" class="login-card__logo" width="100" height="100">
      <h1 class="login-card__title"><%= botName %></h1>
      <p class="text-muted small mb-0">Panel de administraci&oacute;n</p>
    </div>
    <div class="login-card__body">
      <% if (error) { %>
      <div class="alert alert-danger py-2 small"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label">Contrase&ntilde;a</label>
          <input type="password" name="password" class="form-control form-control-lg" required autofocus>
        </div>
        <button type="submit" class="btn btn-brand">Entrar al panel</button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
