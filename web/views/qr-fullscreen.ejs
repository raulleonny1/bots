<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>QR WhatsApp</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: system-ui, Segoe UI, sans-serif;
      background: #e8eaed;
      color: #1a2834;
      padding: 1rem;
    }
  .wrap {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
      padding: 1rem 0 2rem;
    }
    a { color: #1e4d6b; }
    h1 { font-size: 1.35rem; margin: 0.5rem 0; }
    .hint { color: #5c6b78; font-size: 0.95rem; margin-bottom: 1rem; }
    .frame {
      background: #fff;
      padding: 1.25rem;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.12);
      display: inline-block;
      max-width: 100%;
    }
    #qrImg {
      display: block;
      max-width: min(512px, 94vw);
      width: auto;
      height: auto;
      margin: 0 auto;
    }
    .note {
      margin-top: 1rem;
      font-size: 0.85rem;
      color: #5c6b78;
      line-height: 1.5;
    }
    .install-box {
      background: #fff;
      border: 1px solid #d0d7de;
      border-radius: 10px;
      padding: 1rem;
      margin-bottom: 1.25rem;
      text-align: left;
      font-size: 0.9rem;
    }
    .install-box strong { color: #0d5c36; }
  </style>
</head>
<body>
  <div class="wrap">
    <p><a href="/">&larr; Volver al panel</a></p>

    <div class="install-box">
      <strong>En este PC (el otro ordenador) NO instales nada.</strong><br>
      No hace falta Visual Studio Code, Node.js ni npm. Solo abre esta pagina en
      <strong>Chrome</strong> o <strong>Edge</strong> (navegador normal).
      El programa del bot solo corre en el PC de la iglesia.
    </div>

    <% if (hasQr) { %>
    <h1>Escanear con WhatsApp</h1>
    <p class="hint">WhatsApp &rarr; Dispositivos vinculados &rarr; Vincular dispositivo</p>
    <div class="frame">
      <img id="qrImg" src="/api/whatsapp/qr-image" alt="Codigo QR WhatsApp">
    </div>
    <p class="note">
      Si no se ve completo: Ctrl+0 (zoom 100%) o F11 pantalla completa.
      El codigo se refresca solo cada 15 segundos.
    </p>
    <% } else { %>
    <div class="install-box" style="border-color:#ffc107;">
      No hay QR ahora (estado: <strong><%= status %></strong>).
      En el <a href="/">panel</a> del PC de la iglesia pulsa <strong>Conectar</strong>.
    </div>
    <% } %>
  </div>
  <% if (hasQr) { %>
  <script>
    setInterval(function () {
      var img = document.getElementById('qrImg');
      if (img) img.src = '/api/whatsapp/qr-image?t=' + Date.now();
    }, 15000);
  </script>
  <% } %>
</body>
</html>
