# ─── Configuración general ───────────────────────────────────────────────────
NODE_ENV=development
BOT_NAME=Bot Iglesia

# Zona horaria para mensajes programados (ej: Europe/Madrid, America/Mexico_City)
CRON_TIMEZONE=Europe/Madrid

# Hora del mensaje diario (formato 24h)
DAILY_MESSAGE_HOUR=8
DAILY_MESSAGE_MINUTE=0

# Mensaje programado diario
DAILY_MESSAGE_TEXT=Dios bendiga tu día. Todo lo puedo en Cristo.

# Destinatarios del mensaje diario (separados por coma)
# Formato: número con código de país SIN + ni espacios
# Ejemplo para un contacto: 34612345678
# Ejemplo para un grupo: usar el ID del grupo (ver README)
SCHEDULED_RECIPIENTS=34612345678

# ─── OpenAI / ChatGPT ────────────────────────────────────────────────────────
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=400
OPENAI_TEMPERATURE=0.7

# Solo responder con IA si parece pregunta compleja (recomendado: true)
OPENAI_ONLY_QUESTIONS=true
OPENAI_MIN_MESSAGE_LENGTH=25
OPENAI_IGNORE_GREETINGS=true

# Segundos entre respuestas IA por mismo chat (evita spam y costos)
OPENAI_COOLDOWN_MS=15000

# Mensajes de contexto recordados por usuario (pares user/assistant)
OPENAI_MAX_HISTORY_MESSAGES=6

# Solo temas de iglesia / fe (true = recomendado)
OPENAI_CHURCH_TOPICS_ONLY=true

# Mensaje si preguntan algo ajeno a la iglesia (fútbol, trabajo, etc.)
OPENAI_OFF_TOPIC_MESSAGE=Solo puedo ayudarte con temas de nuestra iglesia y la fe. Para otras consultas, escríbenos y un miembro del equipo te atenderá. ¡Bendiciones!

# Opcional: sobrescribe el prompt (usa \n para saltos de línea)
# OPENAI_SYSTEM_PROMPT=

# ─── Panel administrativo web ────────────────────────────────────────────────
# 0.0.0.0 = otros PCs de la red pueden abrir el panel (misma WiFi)
ADMIN_HOST=0.0.0.0
ADMIN_PORT=3000
ADMIN_PASSWORD=cambiar-esta-contraseña
ADMIN_SESSION_SECRET=genera-un-secreto-largo-y-aleatorio

# Por defecto el servidor arranca SIN WhatsApp (conectas desde el panel)
# Solo en PC fijo 24/7 en la iglesia puedes poner: AUTO_CONNECT_WHATSAPP=true
AUTO_CONNECT_WHATSAPP=false

# ─── Reconexión ──────────────────────────────────────────────────────────────
RECONNECT_DELAY_MS=5000
MAX_RECONNECT_ATTEMPTS=10

# ─── Firebase / Firestore ────────────────────────────────────────────────────
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=botsiere
FIREBASE_CHURCH_ID=main
# Descarga JSON en Firebase Console → Cuentas de servicio → Generar nueva clave
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Config web (opcional; el servidor usa cuenta de servicio para escribir)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=botsiere.firebaseapp.com
FIREBASE_STORAGE_BUCKET=botsiere.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
